# PWB Backend API (server-side only — never prefix with VITE_)
PWB_API_URL=https://your-backend.up.railway.app/api/v1/pwbunits/your-unit-slug/
PWB_API_KEY=
PWB_API_SECRET=

# Telegram Bot (client-side — VITE_ prefix exposes to browser)
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# OpenRouter AI Chat (server-side only)
OPENROUTER_KEYS=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=antonblyzniuk.com
