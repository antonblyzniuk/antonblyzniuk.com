VITE_TELEGRAM_CHAT_ID=

# OpenRouter AI Chat (server-side only)
OPENROUTER_KEYS=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=antonblyzniuk.com
