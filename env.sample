# PWB Backend API (server-side only — never prefix with VITE_)
PWB_API_BASE_URL=http://localhost:8000/api/v1
PWB_UNIT_NAME=your-unit-slug
PWB_API_KEY=
PWB_API_SECRET=

# Telegram Bot (client-side — VITE_ prefix exposes to browser)
